# Local-only example values. Copy to .env for private development if needed.

AICO_LLM_ENDPOINT=http://localhost:11434/v1/chat/completions
AICO_LLM_API_KEY=local-dev-key
AICO_LLM_MODEL=your-local-model

AICO_ALGORITHM_URL_PREFIX=http://localhost:22500/mal/
AICO_ALGORITHM_URL_PREFIX_TWO=http://localhost:22500/
AICO_WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

AICO_DB_URL=jdbc:mysql://localhost:3306/aico?useSSL=false&useUnicode=true&characterEncoding=utf-8&serverTimezone=GMT%2B8
AICO_DB_USERNAME=aico
AICO_DB_PASSWORD=change-me
AICO_RABBITMQ_HOST=localhost
AICO_RABBITMQ_PORT=5672
AICO_RABBITMQ_USERNAME=guest
AICO_RABBITMQ_PASSWORD=guest
AICO_SERVER_PORT=8081
